{
  "name": "@flametrench/tenancy",
  "version": "0.3.0",
  "description": "Tenancy primitives for Flametrench: organizations, memberships, invitations. Spec-conformant revoke-and-re-add lifecycle and atomic invitation acceptance.",
  "license": "Apache-2.0",
  "author": {
    "name": "NDC Digital, LLC",
    "url": "https://flametrench.dev"
  },
  "homepage": "https://github.com/flametrench/node",
  "repository": {
    "type": "git",
    "url": "https://github.com/flametrench/node.git",
    "directory": "packages/tenancy"
  },
  "bugs": {
    "url": "https://github.com/flametrench/node/issues"
  },
  "keywords": [
    "flametrench",
    "tenancy",
    "organizations",
    "memberships",
    "invitations",
    "multi-tenancy",
    "postgres"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./postgres": {
      "types": "./dist/postgres.d.ts",
      "import": "./dist/postgres.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@flametrench/ids": "workspace:*"
  },
  "peerDependencies": {
    "pg": "^8.11.0"
  },
  "peerDependenciesMeta": {
    "pg": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.0",
    "pg": "^8.11.0",
    "tsup": "^8.5.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepack": "pnpm build",
    "prepublishOnly": "node ../../scripts/assert-pnpm.mjs"
  }
}
