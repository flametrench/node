{
  "name": "@flametrench/identity",
  "version": "0.0.1",
  "description": "Identity primitives for Flametrench: users, credentials (Argon2id-pinned passwords, passkeys, OIDC), and user-bound sessions with rotation-on-refresh.",
  "license": "Apache-2.0",
  "author": {
    "name": "NDC Digital, LLC",
    "url": "https://flametrench.dev"
  },
  "homepage": "https://github.com/flametrench/node",
  "repository": {
    "type": "git",
    "url": "https://github.com/flametrench/node.git",
    "directory": "packages/identity"
  },
  "bugs": {
    "url": "https://github.com/flametrench/node/issues"
  },
  "keywords": [
    "flametrench",
    "identity",
    "users",
    "credentials",
    "sessions",
    "argon2id",
    "passkey",
    "oidc"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@flametrench/ids": "workspace:*",
    "argon2": "^0.43.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  }
}
